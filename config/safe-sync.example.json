{
  "command_timeout_seconds": 180,
  "debounce_seconds": 20,
  "fallback_interval_seconds": 1800,
  "filter_file": "~/.safe-sync/filter.txt",
  "folders": [
    {
      "enabled": true,
      "filter_file": "~/.safe-sync/filter.txt",
      "id": "safe-sync-test",
      "label": "Safe Sync Test",
      "local_path": "~/safe-sync-test",
      "remote_path": "macbook/safe-sync-test",
      "trash_path": ".trash/macbook/safe-sync-test"
    },
    {
      "enabled": false,
      "filter_file": "~/.safe-sync/filter.txt",
      "id": "data",
      "label": "Data",
      "local_path": "~/data_to_backup",
      "remote_path": "macbook/data",
      "trash_path": ".trash/macbook/data"
    }
  ],
  "install_id": "replace-with-generated-uuid",
  "lock_file": "~/.local/state/safe-sync/safe-sync.lock",
  "log_dir": "~/.local/log/safe-sync",
  "machine": "macbook",
  "machine_id": "macbook",
  "machine_label": "MacBook",
  "min_interval_seconds": 120,
  "poll_interval_seconds": 5,
  "preserve_metadata": false,
  "rate_limit_backoff_seconds": 300,
  "rclone_max_duration_seconds": 120,
  "remote_base": "dropbox:computer-backups/test",
  "status_path": "~/.local/state/safe-sync/status.json"
}
